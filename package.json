{
  "name": "bloghunch-mcp",
  "version": "2.0.0",
  "description": "Connect Claude, Cursor, and ChatGPT directly to your Bloghunch publication",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "bloghunch-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "bloghunch",
    "mcp",
    "model-context-protocol",
    "claude",
    "chatgpt",
    "cursor",
    "ai",
    "blogging"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "dev": "npx tsx index.ts",
    "dev:http": "TRANSPORT=http npx tsx index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.5.0"
  }
}
