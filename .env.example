# ── STDIO mode (Claude Desktop / Cursor) ──────────────────────────────────────
BLOGHUNCH_API_KEY=bh_live_xxxxxxxxxxxx
BLOGHUNCH_SUBDOMAIN=your-subdomain        # optional — only if you have multiple publications
BLOGHUNCH_API_URL=https://api.bloghunch.com/api/v1

# ── HTTP mode (ChatGPT) — set TRANSPORT=http to enable ────────────────────────
TRANSPORT=stdio                            # change to "http" for ChatGPT mode
PORT=3001
MCP_SERVER_URL=https://mcp.yourdomain.com  # public HTTPS URL of this server
