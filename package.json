{
  "name": "bloghunch-mcp-server",
  "version": "1.1.0",
  "description": "Bloghunch MCP Server — STDIO (Claude/Cursor) + HTTP (ChatGPT)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "dev": "npx tsx index.ts",
    "dev:http": "TRANSPORT=http npx tsx index.ts",
    "install-claude": "node scripts/install-claude.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.5.0"
  }
}
