# ── STDIO mode (Claude Desktop / Cursor) ──────────────────────────────────────
# Required: your Bloghunch Developer API key
BLOGHUNCH_API_KEY=bh_live_xxxxxxxxxxxx

# Optional: only needed if you manage multiple publications
BLOGHUNCH_SUBDOMAIN=your-subdomain

# Optional: override API base (defaults to https://api.bloghunch.com/api/v1)
BLOGHUNCH_API_URL=https://api.bloghunch.com/api/v1

# ── HTTP mode (ChatGPT) — set TRANSPORT=http to enable ────────────────────────
# Change to "http" for the hosted ChatGPT server
TRANSPORT=stdio

# Port the HTTP server listens on
PORT=3001

# Public HTTPS URL of this server (used in OAuth discovery + token endpoint URLs)
MCP_SERVER_URL=https://mcp.yourdomain.com

# Optional: path to the SQLite token database (defaults to tokens.db in CWD)
# TOKEN_DB_PATH=/var/www/mcp/tokens.db
